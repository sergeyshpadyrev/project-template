{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": ["PORT"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**", "dist/**"]
    },
    "check:format": { "dependsOn": ["^check:format"] },
    "check:format:fix": { "dependsOn": ["^check:format:fix"] },
    "check:lint": { "dependsOn": ["^check:lint"] },
    "check:lint:fix": { "dependsOn": ["^check:lint:fix"] },
    "check:types": { "dependsOn": ["^check:types"] },
    "dev": { "cache": false, "persistent": true }
  }
}
