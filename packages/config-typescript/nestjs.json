{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "isolatedModules": false,
    "lib": ["es2022"],
    "outDir": "${configDir}/dist",
    "sourceMap": true,
    "strictPropertyInitialization": false
  }
}
