{
  "name": "web-app",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "vite build",
    "check:format": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md}\"",
    "check:format:fix": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md}\"",
    "check:lint": "eslint . --max-warnings 0",
    "check:lint:fix": "eslint . --fix",
    "check:types": "tsc --noEmit",
    "dev": "vite",
    "preview": "vite preview"
  },
  "dependencies": {
    "@repo/config-ports": "*",
    "@repo/sdk-app-react": "*",
    "@repo/types-app": "*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@repo/config-eslint": "*",
    "@repo/config-typescript": "*",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.39.1",
    "typescript": "5.9.2",
    "vite": "^7.0.0"
  }
}
